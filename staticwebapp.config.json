{
  "routes": [
    { "route": "/login", "rewrite": "/.auth/login/aad" },
    { "route": "/logout", "redirect": "/.auth/logout" },
    { "route": "/*", "allowedRoles": ["authenticated"] },
    { "route": "/*", "allowedRoles": ["approved"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  }
}
